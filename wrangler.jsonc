{
  "name": "zai",
  "compatibility_date": "2024-01-01",
  "pages_build_output_dir": "./dist",
  "vars": {
    "APP_ENV": "prod",
    "APP_URL": "https://zai.htu.io",
    "HTU_ENV": "prod"
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  }
}
