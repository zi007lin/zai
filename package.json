{
  "name": "zai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy:dev": "npm run build && npx wrangler pages deploy dist/ --project-name zai --branch dev",
    "deploy:demo": "npm run build && npx wrangler pages deploy dist/ --project-name zai --branch demo",
    "deploy:full": "npm run build && npx wrangler pages deploy dist/ --project-name zai --branch main"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "i18next": "^23.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^4.1.4",
    "wrangler": "^3.80.0"
  }
}
