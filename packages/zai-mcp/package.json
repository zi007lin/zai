{
  "name": "@htu/zai-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing ZAI's score_spec tool over stdio. Demo subset (#80).",
  "license": "MIT",
  "author": "ZiLin <noreply@zzv.io>",
  "homepage": "https://github.com/zi007lin/zai/tree/main/packages/zai-mcp",
